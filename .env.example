# MovieNexus Environment Variables

# ===== API Keys (Required) =====
TMDB_API_KEY=your_tmdb_api_key_here
TVDB_API_KEY=your_tvdb_api_key_here

# ===== API Keys (Optional) =====
FANART_API_KEY=your_fanart_api_key_here
TRAKT_CLIENT_ID=your_trakt_client_id_here

# ===== Plex Integration (Optional) =====
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# ===== Database =====
DATABASE_URL=postgresql://postgres:password@db:5432/movienexus
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=movienexus

# ===== Backend =====
SECRET_KEY=your_jwt_secret_key_here_min_32_chars
BACKEND_PORT=8910
BACKEND_HOST=0.0.0.0
DEBUG=false

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8910/api

# ===== Redis (Optional, for caching) =====
REDIS_URL=redis://redis:6379/0

# ===== Deployment =====
ENVIRONMENT=development
DOMAIN=movienexus.local
